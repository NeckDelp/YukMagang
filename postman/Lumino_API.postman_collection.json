{
	"info": {
		"_postman_id": "lumino-api-collection",
		"name": "Lumino Backend API",
		"description": "Complete API collection for Lumino Internship Management System",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"auth": {
		"type": "bearer",
		"bearer": [
			{
				"key": "token",
				"value": "{{token}}",
				"type": "string"
			}
		]
	},
	"item": [
		{
			"name": "Authentication",
			"item": [
				{
					"name": "Login",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 200) {",
									"    const response = pm.response.json();",
									"    if (response.data && response.data.token) {",
									"        pm.environment.set('token', response.data.token);",
									"        ",
									"        // Set role-specific tokens",
									"        if (response.data.user && response.data.user.role) {",
									"            const role = response.data.user.role;",
									"            if (role === 'student') {",
									"                pm.environment.set('student_token', response.data.token);",
									"            } else if (role === 'company') {",
									"                pm.environment.set('company_token', response.data.token);",
									"            } else if (role === 'school_admin') {",
									"                pm.environment.set('school_admin_token', response.data.token);",
									"            } else if (role === 'teacher') {",
									"                pm.environment.set('teacher_token', response.data.token);",
									"            } else if (role === 'super_admin') {",
									"                pm.environment.set('super_admin_token', response.data.token);",
									"            }",
									"        }",
									"    }",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"auth": {
							"type": "noauth"
						},
						"method": "POST",
						"header": [
							{
								"key": "Accept",
								"value": "application/json"
							},
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"student@example.com\",\n    \"password\": \"password123\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/auth/login",
							"host": ["{{base_url}}"],
							"path": ["auth", "login"]
						}
					}
				},
